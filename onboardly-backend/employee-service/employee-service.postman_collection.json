              "formdata": [
                { "key": "step", "value": "I_983", "type": "text", "description": "One of: I_983, I_20, OPT_RECEIPT, OPT_EAD" },
                { "key": "file", "type": "file", "description": "PDF, JPG, or PNG — max 10 MB" },
                { "key": "eadStartDate", "value": "2025-01-01", "type": "text", "disabled": true, "description": "Required only for OPT_EAD step (YYYY-MM-DD)" },
                { "key": "eadEndDate",   "value": "2027-01-01", "type": "text", "disabled": true, "description": "Required only for OPT_EAD step (YYYY-MM-DD)" }
              ]
