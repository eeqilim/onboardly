{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Employee Service",
    "description": "All endpoints for the employee-service microservice (port 8082).\n\nSet `jwtToken` to a token obtained from POST /auth/login on the auth-server.\nUse `hrJwtToken` / `employeeJwtToken` to store tokens for each role, then copy the one you need into `jwtToken` before running a request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",          "value": "http://localhost:8082" },
    { "key": "jwtToken",         "value": "<paste token here>",  "description": "Active JWT — set this before running any request" },
    { "key": "hrJwtToken",       "value": "",                     "description": "Store your HR-role token here" },
    { "key": "employeeJwtToken", "value": "",                     "description": "Store your EMPLOYEE-role token here" },
    { "key": "employeeId",       "value": "",                     "description": "MongoDB ObjectId of the target employee (String)" },
    { "key": "applicationId",    "value": "",                     "description": "MongoDB ObjectId of the onboarding application" },
    { "key": "visaStatusId",     "value": "",                     "description": "MongoDB ObjectId of the visa status" },
    { "key": "documentId",       "value": "",                     "description": "MongoDB ObjectId of the personal document" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const token = pm.collectionVariables.get('jwtToken');",
          "if (token) {",
          "  pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Employee Profile",
      "item": [
        {
          "name": "Get my profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/employee/profile/me",
              "host": ["{{baseUrl}}"],
              "path": ["employee", "profile", "me"]
            }
          }
        },
        {
          "name": "Get profile by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/employee/profile/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["employee", "profile", "{{employeeId}}"]
            }
          }
        },
        {
          "name": "Get full profile by ID (HR only)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/employee/profile/{{employeeId}}/full",
              "host": ["{{baseUrl}}"],
              "path": ["employee", "profile", "{{employeeId}}", "full"]
            }
          }
        },
        {
          "name": "Update name",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/employee/profile/{{employeeId}}/name",
              "host": ["{{baseUrl}}"],
              "path": ["employee", "profile", "{{employeeId}}", "name"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"middleName\": \"Michael\",\n  \"preferredName\": \"Johnny\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update address",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/employee/profile/{{employeeId}}/address",
              "host": ["{{baseUrl}}"],
              "path": ["employee", "profile", "{{employeeId}}", "address"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"PRIMARY\",\n  \"addressLine1\": \"123 Main St\",\n  \"addressLine2\": \"Apt 4B\",\n  \"city\": \"New York\",\n  \"state\": \"NY\",\n  \"zipCode\": \"10001\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update contact",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/employee/profile/{{employeeId}}/contact",
              "host": ["{{baseUrl}}"],
              "path": ["employee", "profile", "{{employeeId}}", "contact"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"EMERGENCY\",\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"middleName\": null,\n  \"cellPhone\": \"5550001234\",\n  \"alternatePhone\": null,\n  \"email\": \"jane.doe@example.com\",\n  \"relationship\": \"Spouse\",\n  \"address\": \"123 Main St, New York, NY 10001\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update employment",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/employee/profile/{{employeeId}}/employment",
              "host": ["{{baseUrl}}"],
              "path": ["employee", "profile", "{{employeeId}}", "employment"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employmentStartDate\": \"2024-01-15\",\n  \"employmentEndDate\": null,\n  \"driverLicense\": \"D1234567\",\n  \"driverLicenseExpiration\": \"2028-06-30\",\n  \"houseId\": null\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Onboarding",
      "item": [
        {
          "name": "Get onboarding profile by employee ID (HR only)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/employee/onboarding/hr/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["employee", "onboarding", "hr", "{{employeeId}}"]
            },
            "description": "Returns the full employee profile (all onboarding-submitted data) for HR review."
          }
        },
        {
          "name": "Get my application",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/employee/onboarding/me",
              "host": ["{{baseUrl}}"],
              "path": ["employee", "onboarding", "me"]
            }
          }
        },
        {
          "name": "Start application",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/employee/onboarding/start",
              "host": ["{{baseUrl}}"],
              "path": ["employee", "onboarding", "start"]
            }
          }
        },
        {
          "name": "Submit application",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/employee/onboarding/submit",
              "host": ["{{baseUrl}}"],
              "path": ["employee", "onboarding", "submit"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"middleName\": null,\n  \"preferredName\": \"Johnny\",\n  \"email\": \"john.doe@example.com\",\n  \"cellPhone\": \"5550001234\",\n  \"alternatePhone\": null,\n  \"gender\": \"MALE\",\n  \"ssn\": \"123-45-6789\",\n  \"dateOfBirth\": \"1990-05-15\",\n  \"citizenshipStatus\": \"CITIZEN\",\n  \"driverLicense\": \"D1234567\",\n  \"driverLicenseExpiration\": \"2028-06-30\",\n  \"address\": {\n    \"type\": \"PRIMARY\",\n    \"addressLine1\": \"123 Main St\",\n    \"addressLine2\": null,\n    \"city\": \"New York\",\n    \"state\": \"NY\",\n    \"zipCode\": \"10001\"\n  },\n  \"referenceContact\": {\n    \"type\": \"REFERENCE\",\n    \"firstName\": \"Alice\",\n    \"lastName\": \"Smith\",\n    \"middleName\": null,\n    \"cellPhone\": \"5550009876\",\n    \"alternatePhone\": null,\n    \"email\": \"alice.smith@example.com\",\n    \"relationship\": \"Manager\",\n    \"address\": null\n  },\n  \"emergencyContacts\": [\n    {\n      \"type\": \"EMERGENCY\",\n      \"firstName\": \"Jane\",\n      \"lastName\": \"Doe\",\n      \"middleName\": null,\n      \"cellPhone\": \"5550005678\",\n      \"alternatePhone\": null,\n      \"email\": \"jane.doe@example.com\",\n      \"relationship\": \"Spouse\",\n      \"address\": null\n    }\n  ],\n  \"visaInfo\": null\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "List pending applications (HR only)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/employee/onboarding/pending",
              "host": ["{{baseUrl}}"],
              "path": ["employee", "onboarding", "pending"]
            }
          }
        },
        {
          "name": "Review application (HR only)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/employee/onboarding/{{applicationId}}/review",
              "host": ["{{baseUrl}}"],
              "path": ["employee", "onboarding", "{{applicationId}}", "review"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APPROVED\",\n  \"hrFeedback\": \"All documents verified.\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
